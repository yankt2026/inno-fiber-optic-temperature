---
import Base from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import SystemDiagram from '../components/SystemDiagram.astro';
import {products} from '../data/products';
import {solutions,resources} from '../data/pages';
import {site} from '../config/site';
const faqs=[{q:'What is a fluorescent fiber optic temperature sensor?',a:'It is a point sensor that sends light to a fluorescent tip and calculates temperature from the decay lifetime of the returned emission.'},{q:'Why use fiber optic temperature probes in transformers?',a:'The probe is passive and dielectric at the measurement point, supporting direct winding measurements without conductive sensor wiring in the high-voltage region.'},{q:'Are channel count and communication fixed?',a:'No. The final specification depends on the selected instrument. Confirm channel count and interfaces on the product datasheet.'}];
const schema=[{'@context':'https://schema.org','@type':'Organization',name:site.companyName,brand:'INNO',url:site.siteUrl,email:site.email,logo:`${site.siteUrl}/images/logo/inno-logo.png`},{'@context':'https://schema.org','@type':'WebSite',name:site.siteName,url:site.siteUrl}];
---
<Base title="Fiber Optic Temperature Sensors & Monitoring Systems | INNO" description="INNO manufactures fluorescent fiber optic temperature sensors, probes and temperature monitoring systems for transformers, windings, reactors, switchgear and high-voltage EMI environments." schema={schema}>
  <section class="hero"><div class="container hero-grid"><div><p class="eyebrow">Direct optical measurement at the thermal point</p><h1>Fiber Optic Temperature Sensors and Monitoring Systems</h1><p>Fluorescence-lifetime probes, multi-channel instruments and application engineering for transformer windings, reactors, switchgear and high-voltage EMI/RFI environments.</p><div class="actions"><a class="button" href="/products/">Explore products</a><a class="text-link" href="/contact/">Discuss a project →</a></div></div><aside class="hero-card"><p class="eyebrow">Measurement chain</p><strong>Probe → Instrument → Plant</strong><ul><li>Passive dielectric sensing point</li><li>Point-based temperature measurement</li><li>Configurable monitoring architecture</li></ul></aside></div></section>

  <section class="section"><div class="container"><div class="section-head"><p class="eyebrow">Core products</p><h2>One optical measurement chain, configured around your equipment</h2><p class="lead">Select the probe for the thermal interface, the instrument for channel and integration needs, and the installation architecture for the equipment insulation system.</p></div><div class="grid">{products.slice(0,6).map(p=><article class="card linked-card product-card">{p.image&&<a class="product-image-link" href={`/products/${p.slug}/`} aria-label={`View ${p.name}`}><img src={p.image} alt={`${p.name} product view`} loading="lazy"></a>}<h3><a href={`/products/${p.slug}/`}>{p.name}</a></h3><p>{p.summary}</p></article>)}</div></div></section>

  <section class="section tint"><div class="container"><div class="section-head"><p class="eyebrow">Fluorescence lifetime</p><h2>Temperature derived from optical decay, not electrical signals</h2><p class="lead">Excitation light reaches a fluorescent sensing tip through quartz fiber. The monitor analyzes the temperature-dependent emission lifetime, keeping the sensing point passive and immune to EMI/RFI.</p></div><SystemDiagram/></div></section>

  <section class="section"><div class="container"><div class="section-head"><p class="eyebrow">Power equipment</p><h2>Measure representative thermal points conventional methods cannot easily reach</h2></div><div class="grid">{solutions.slice(0,6).map(s=><article class="card linked-card color-shift-card metric"><h3><a href={`/solutions/${s.slug}/`}>{s.title}</a></h3><p>{s.intro}</p></article>)}</div></div></section>

  <section class="section tint"><div class="container product-hero"><div><p class="eyebrow">Transformer winding hot spots</p><h2>Plan embedded measurement before winding manufacture</h2><p class="lead">Probe placement, fixation, optical routing, fiber exit and channel identification should be part of transformer thermal and insulation design—not an afterthought during commissioning.</p><a class="button" href="/solutions/transformer-winding-hotspot-monitoring/">View winding approach</a></div><img src="/images/solutions/transformer-winding-monitoring.webp" alt="Transformer winding fiber optic temperature monitoring arrangement" loading="lazy"></div></section>

  <section class="section"><div class="container"><div class="section-head"><p class="eyebrow">Product selection</p><h2>Specify what must be measured before choosing a model</h2></div><div class="grid"><div class="card"><h3>1. Measurement points</h3><p>Define the physical point, its thermal purpose and the installation stage.</p></div><div class="card"><h3>2. Operating envelope</h3><p>State expected temperature, dielectric environment, routing and mechanical constraints.</p></div><div class="card"><h3>3. System interface</h3><p>Define channels, alarm ownership, display and plant communication requirements.</p></div></div></div></section>

  <section class="section tint"><div class="container"><div class="section-head"><p class="eyebrow">Technical resources</p><h2>Make the measurement architecture defensible</h2></div><div class="grid">{resources.slice(0,6).map(r=><article class="card linked-card"><h3><a href={`/resources/${r.slug}/`}>{r.title}</a></h3><p>{r.description}</p></article>)}</div><FAQ items={faqs}/></div></section>
</Base>
