---
import Base from '../../layouts/BaseLayout.astro';import CTA from '../../components/CTA.astro';import FAQ from '../../components/FAQ.astro';import SystemDiagram from '../../components/SystemDiagram.astro';import {solutions} from '../../data/pages';import {products} from '../../data/products';
export function getStaticPaths(){
  return solutions.map(page=>({params:{slug:page.slug},props:{page}}));
}
const {page}=Astro.props;const crumbs=[{name:'Home',url:'/'},{name:'Solutions',url:'/solutions/'},{name:page.title,url:`/solutions/${page.slug}/`}];const schema=[{'@context':'https://schema.org','@type':'Service',name:page.title,description:page.description,provider:{'@type':'Organization',name:'INNO'}},{'@context':'https://schema.org','@type':'FAQPage',mainEntity:page.faqs.map((f:any)=>({'@type':'Question',name:f.q,acceptedAnswer:{'@type':'Answer',text:f.a}}))}];
---
<Base title={`${page.title} | INNO`} description={page.description} breadcrumbs={crumbs} schema={schema}><section class="page-hero"><div class="container"><p class="eyebrow">Application engineering</p><h1>{page.title}</h1><p>{page.intro}</p></div></section><section class="section"><div class="container prose">{page.sections.map((s:any)=><><h2>{s.heading}</h2><p>{s.body}</p></>)}<h2>Monitoring system architecture</h2></div><div class="container"><SystemDiagram/></div></section><section class="section tint"><div class="container"><div class="section-head"><p class="eyebrow">Confirmed product families</p><h2>Build the measurement chain</h2></div><div class="grid">{products.slice(0,3).map(p=><article class="card"><h3><a href={`/products/${p.slug}/`}>{p.name}</a></h3><p>{p.summary}</p><a class="arrow" href={`/products/${p.slug}/`}>Review product →</a></article>)}</div><FAQ items={page.faqs}/></div></section><CTA title={`Plan ${page.title}`}/></Base>
