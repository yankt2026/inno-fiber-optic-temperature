---
import Base from '../../layouts/BaseLayout.astro';import CTA from '../../components/CTA.astro';import {products} from '../../data/products';
---
<Base title="Fiber Optic Temperature Sensors & Systems | INNO" description="Explore INNO fluorescent fiber optic temperature probes, multi-channel monitors, transformer systems and OEM sensing modules."><section class="page-hero"><div class="container"><p class="eyebrow">Product portfolio</p><h1>Fiber Optic Temperature Sensors and Measurement Systems</h1><p>Build a point-based optical measurement chain from the probe to the monitoring instrument and plant interface.</p></div></section><section class="section"><div class="container grid">{products.map(p=><article class="card linked-card product-card">{p.image&&<a class="product-image-link" href={`/products/${p.slug}/`} aria-label={`View ${p.name}`}><img src={p.image} alt={`${p.name} product image`} loading="lazy"></a>}<p class="eyebrow">{p.category}</p><h2><a href={`/products/${p.slug}/`}>{p.name}</a></h2><p>{p.summary}</p></article>)}</div></section><CTA/></Base>
