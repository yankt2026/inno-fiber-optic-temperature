---
import Base from '../../layouts/BaseLayout.astro';import CTA from '../../components/CTA.astro';import FAQ from '../../components/FAQ.astro';import SystemDiagram from '../../components/SystemDiagram.astro';import {products} from '../../data/products';import {site} from '../../config/site';
export function getStaticPaths(){
  return products.map(product=>({params:{slug:product.slug},props:{product}}));
}
const {product}=Astro.props;
const crumbs=[{name:'Home',url:'/'},{name:'Products',url:'/products/'},{name:product.name,url:`/products/${product.slug}/`}];
const schema=[{'@context':'https://schema.org','@type':'Product',name:product.name,model:product.model,description:product.summary,brand:{'@type':'Brand',name:'INNO'},image:product.image?`${site.siteUrl}${product.image}`:undefined},{'@context':'https://schema.org','@type':'FAQPage',mainEntity:product.faqs.map((f:any)=>({'@type':'Question',name:f.q,acceptedAnswer:{'@type':'Answer',text:f.a}}))}];
---
<Base title={product.seoTitle} description={product.seoDescription} breadcrumbs={crumbs} schema={schema}><section class="page-hero"><div class:list={["container",product.image&&"product-hero"]}><div><p class="eyebrow">{product.category}</p><h1>{product.name}</h1><p>{product.summary}</p><div class="actions"><a class="button" href="/contact/">Request specifications</a><a class="text-link" href="#specifications">View confirmed data ↓</a></div></div>{product.image&&<img src={product.image} alt={`${product.name} product view`} width="560" height="420">}</div></section><section class="section"><div class="container"><div class="section-head"><p class="eyebrow">Confirmed capabilities</p><h2>Engineered for electrically demanding temperature points</h2></div><div class="grid">{product.confirmedFeatures.map((x:string)=><div class="card metric"><h3>{x}</h3><p>Confirmed for this product family; final implementation follows the selected model datasheet.</p></div>)}</div></div></section><section id="specifications" class="section tint"><div class="container"><div class="section-head"><p class="eyebrow">Technical data</p><h2>Confirmed Specifications</h2><p>Only values confirmed on the permitted INNO product pages are listed. Configuration-specific items remain explicitly qualified.</p></div><table class="spec"><tbody>{Object.entries(product.confirmedSpecifications).map(([k,v])=><tr><th>{k}</th><td>{v}</td></tr>)}</tbody></table></div></section><section class="section"><div class="container"><div class="prose"><h2>Operating principle</h2><p>{product.operatingPrinciple}</p><h2>Installation approach</h2><p>{product.installation}</p><h2>Communication and system integration</h2><p>{product.communication}</p><p>{product.systemIntegration}</p></div><SystemDiagram/></div></section><section class="section tint"><div class="container"><div class="section-head"><h2>Typical Applications</h2></div><div class="grid">{product.applications.map((x:string)=><div class="card"><h3>{x}</h3><p>Confirm probe location, routing and instrument configuration against the equipment design.</p></div>)}</div></div></section><div class="container"><FAQ items={product.faqs}/></div><CTA title={`Specify ${product.name}`}/></Base>
