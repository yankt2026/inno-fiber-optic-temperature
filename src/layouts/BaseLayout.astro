---
import {site} from '../config/site'; import '../styles/global.css'; import '../styles/cards.css';
interface Props{title:string;description:string;path?:string;breadcrumbs?:{name:string;url:string}[];schema?:Record<string,unknown>|Record<string,unknown>[]}
const {title,description,path=Astro.url.pathname,breadcrumbs=[],schema}=Astro.props;
const canonical=new URL(path,site.siteUrl).toString();
const crumbSchema=breadcrumbs.length?{'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:breadcrumbs.map((b,i)=>({'@type':'ListItem',position:i+1,name:b.name,item:new URL(b.url,site.siteUrl).toString()}))}:null;
const json=[...(Array.isArray(schema)?schema:schema?[schema]:[]),...(crumbSchema?[crumbSchema]:[])];
const nav=[['Products','/products/'],['Solutions','/solutions/'],['Technology','/technology/'],['Resources','/resources/'],['About','/about/'],['Contact','/contact/']];
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><title>{title}</title><meta name="description" content={description}><link rel="canonical" href={canonical}><meta property="og:type" content="website"><meta property="og:title" content={title}><meta property="og:description" content={description}><meta property="og:url" content={canonical}><meta property="og:site_name" content={site.siteName}><meta name="twitter:card" content="summary"><meta name="theme-color" content="#0B2A4A">{json.map(item=><script is:inline type="application/ld+json" set:html={JSON.stringify(item)}/>)}</head>
<body><a class="skip" href="#main">Skip to content</a><header class="site-header"><div class="utility"><div class="container">Fluorescent fiber optic temperature measurement <a href={`mailto:${site.email}`}>{site.email}</a></div></div><div class="container nav-wrap"><a class="brand" href="/" aria-label="INNO home"><img src="/images/logo/inno-logo.png" alt="INNO" width="154" height="58"></a><button class="menu" aria-expanded="false" aria-controls="nav">Menu</button><nav id="nav" aria-label="Primary"><a href="/">Home</a>{nav.map(([label,url])=><a href={url}>{label}</a>)}</nav></div></header>
<main id="main">{breadcrumbs.length > 0 ? <nav class="breadcrumbs container" aria-label="Breadcrumb">{breadcrumbs.map((b,i)=><><a href={b.url}>{b.name}</a>{i < breadcrumbs.length - 1 ? <span>/</span> : null}</>)}</nav> : null}<slot/></main>
<footer><div class="container footer-grid"><div><img src="/images/logo/inno-logo.png" alt="INNO" width="140"><p>Point-based fluorescent fiber optic temperature sensing for transformers, switchgear and high-voltage equipment.</p></div><div><h2>Explore</h2><a href="/products/">Products</a><a href="/solutions/">Solutions</a><a href="/resources/">Technical resources</a><a href="/sitemap/">Sitemap</a></div><div><h2>Contact</h2><p>{site.companyName}</p><a href={`mailto:${site.email}`}>{site.email}</a><a href="/privacy-policy/">Privacy policy</a></div></div></footer>
<script is:inline>const b=document.querySelector('.menu'),n=document.querySelector('#nav');b?.addEventListener('click',()=>{const x=b.getAttribute('aria-expanded')==='true';b.setAttribute('aria-expanded',String(!x));n?.classList.toggle('open')})</script></body></html>
